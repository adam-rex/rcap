# Copy to .env.local in this directory (rex-robson). Next.js does not load the parent folder .env automatically.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Auth: in Supabase Dashboard → Authentication → URL configuration, add redirect URLs:
#   http://localhost:3000/auth/callback
#   https://your-production-host/auth/callback
# Disable public signups if only you should have accounts (Authentication → Providers → Email).

NEXT_PUBLIC_ANTHROPIC_API_KEY=
# Preferred for /api/rex/search (server-only; not exposed to the browser).
# ANTHROPIC_API_KEY=
# Optional override (default claude-3-5-sonnet-20241022).
# ANTHROPIC_MODEL=
NEXT_PUBLIC_OPENAI_API_KEY=

# Optional aliases (server-only tooling); browser code must use NEXT_PUBLIC_* anon key above.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Service role for trusted server scripts only — never expose to the client or use NEXT_PUBLIC_*.
# Required for: npm run db:seed (scripts/seed). Also accepts NEXT_PUBLIC_SUPABASE_SERVICE_ROLE_KEY
# if present; prefer SUPABASE_SERVICE_ROLE_KEY. See npm run db:seed -- --help for CLI options.
# Required in production for SendGrid inbound parse: POST has no user session, so ingests use the
# service-role client (bypasses RLS). Generic POST /api/rex/email/ingest with REX_EMAIL_INGEST_SECRET
# also requires this key. Logged-in browser capture uses the session + anon key only.
# SUPABASE_SERVICE_ROLE_KEY=

# SendGrid Inbound Parse → POST /api/rex/email/ingest/sendgrid?secret=…
# Required in production: without it the SendGrid route returns 401. Dev may omit for local tests.
# SendGrid UI: Inbound Parse → destination URL with POST raw MIME; DNS MX to SendGrid.
# SENDGRID_INBOUND_PARSE_SECRET=

# Optional: POST /api/rex/email/ingest (generic JSON/multipart). When set, relay servers may call
# the same path with ?secret=… or header X-Rex-Ingest-Secret. Production always requires a logged-in
# Supabase session unless this secret matches (see lib/email/ingest-route-auth.ts).
# REX_EMAIL_INGEST_SECRET=

# Optional: npm run verify:rex-email — after starting dev server, set to hit POST /api/rex/email/ingest.
# E2E_NEXT_BASE_URL=http://localhost:3000
